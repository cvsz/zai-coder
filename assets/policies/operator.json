{
    "name": "operator",
    "description": "Local runtime operations",
    "allowed_commands": ["ls", "cat", "grep", "find", "head", "tail", "pytest", "python", "python3", "make", "npm", "yarn", "git", "bash", "sh", "chmod", "echo", "rm", "mkdir", "docker", "cargo", "patch", "diff"],
    "denied_patterns": ["rm -rf /", "sudo rm -rf", "git push --force"],
    "protected_paths": ["apps/zlms/"],
    "generated_paths": ["node_modules/", "dist/", ".next/", "coverage/", "reports/", ".turbo/", ".vite/", "vendor/ai-assets/"],
    "max_timeout_seconds": 300,
    "require_approval": false,
    "allow_network": true,
    "allow_shell": false,
    "allow_write": true
}
