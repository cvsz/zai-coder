# ZAI Coder Control Plane environment example
# Copy to .env and edit values before production use.
# This file is safe to commit because it contains placeholders only.

ZAI_ENV=production
ZAI_HOST=127.0.0.1
ZAI_PORT=8765
ZAI_DOMAIN=zai-coder.local

# Use PostgreSQL for production. Keep real credentials outside git.
DATABASE_URL=postgresql://zai:change-me@127.0.0.1:5432/zai

# Session secret should be generated locally. Do not commit a real value.
ZAI_SESSION_SECRET=replace-with-generated-secret

# Cloudflare optional
CLOUDFLARE_TUNNEL_NAME=zai-coder
CLOUDFLARE_HOSTNAME=zai-coder.local

# Runtime paths
ZAI_DATA_DIR=.zai-coder/data
ZAI_LOGS_DIR=.zai-coder/logs
ZAI_BACKUP_DIR=.zai-coder/backups
ZAI_STORAGE_DIR=.zai-coder/storage
