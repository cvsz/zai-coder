# ZAI Coder self-dev automation config.
# Copy to configs/zai-self-dev.env for local overrides.
# Keep values quoted: this file is sourced by bash.

ZAI_REPO_DIR="/home/zeazdev/zai-coder"
ZAI_REPO_FULL_NAME="cvsz/zai-coder"
ZAI_MAIN_BRANCH="main"

# Prefer an external venv so repo-local .venv is never committed.
ZAI_VENV="/home/zeazdev/.venvs/zai-coder"

ZAI_MASTER_PROMPT="docs/prompts/MASTER-FINAL-IMPLEMENTATION.md"
ZAI_PHASE_PROMPT="docs/prompts/25-self-queue-production.md"

ZAI_PHASE_ID="phase1"
ZAI_PHASE_NAME="self-queue-production"
ZAI_BRANCH="feat/self-queue-production"
ZAI_PR_TITLE="feat: add production self-queue"
ZAI_PR_BODY="Adds durable local self-queue storage, task lifecycle commands, bounded worker behavior, retry/cancel/logs, TUI task status, tests, and operator docs."

ZAI_AGENTS="planner,coder,reviewer"
ZAI_STAGE_FILE_LIST="configs/zai-self-dev.phase1.files"
ZAI_MODEL_TIMEOUT_SECONDS="120"

DRY_RUN="1"
APPLY="0"
COMMIT="0"
CREATE_PR="0"
